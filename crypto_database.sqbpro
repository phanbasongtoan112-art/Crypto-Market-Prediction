<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="crypto_database.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="1"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="896"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="ai_6_years_predictions" custom_title="0" dock_id="2" table="4,22:mainai_6_years_predictions"/><dock_state state="000000ff00000000fd00000001000000020000043b000002aefc0100000002fb000000160064006f0063006b00420072006f007700730065003101000000000000043b0000000000000000fb000000160064006f0063006b00420072006f007700730065003201000000000000043b0000012d00ffffff0000025a0000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="ai_6_years_predictions" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="156"/><column index="2" value="81"/><column index="3" value="132"/><column index="4" value="140"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">-- Dữ liệu thô nguyên thủy (Gồm 6 cột cơ bản)
SELECT * FROM raw_ohlcv 
ORDER BY timestamp ASC;

-- Dữ liệu đã làm sạch và thêm Feature (RSI, MACD)
SELECT timestamp, open, high, low, close, volume, RSI, MACD 
FROM spot_ohlcv 
ORDER BY timestamp ASC;
-- Bảng thống kê tổng quan toàn bộ chu kỳ 6 năm
SELECT 
    COUNT(*) as Tong_So_Ngay_Giao_Dich,
    MIN(close) as Gia_Nho_Nhat_Min,
    MAX(close) as Gia_Lon_Nhat_Max,
    AVG(close) as Gia_Trung_Binh_Mean,
    MIN(volume) as Volume_Thap_Nhat,
    MAX(volume) as Volume_Cao_Nhat
FROM spot_ohlcv;
-- 3.kiểm tra chéo xem AI tính sai số (Difference) có đúng như trên Dashboard không
SELECT Date, Actual_Value, Predicted_Value, Difference
FROM ai_6_years_predictions
ORDER BY Date DESC;	</sql><current_tab id="0"/></tab_sql></sqlb_project>
